+// Resolve the SP role for THIS init call, based on env var + counter.
+// Caller already holds g_sp_map_mtx.
+static sp_llama_role_t resolve_init_role(const llama_model * model) {
+    const char * spec_env = std::getenv("SHANNON_PRIME_SPEC");
+    if (!spec_env || spec_env[0] != '1') {
+        return SP_LLAMA_ROLE_DEFAULT;
+    }
+    const int idx = g_sp_init_counter.fetch_add(1, std::memory_order_relaxed);
+    switch (idx) {
+        case 0:
+            std::fprintf(stderr,
+                "[Shannon-Prime] SPEC=1: model %p assigned ROLE_TARGET (init #1)\n",
+                (const void *)model);
+            return SP_LLAMA_ROLE_TARGET;
+        case 1:
+            std::fprintf(stderr,
+                "[Shannon-Prime] SPEC=1: model %p assigned ROLE_DRAFT (init #2)\n",
+                (const void *)model);
+            return SP_LLAMA_ROLE_DRAFT;
+        default:
+            std::fprintf(stderr,
+                "[Shannon-Prime] SPEC=1: model %p init #%d > 2 — falling back to "
+                "ROLE_DEFAULT (only target+draft are role-disambiguated)\n",
+                (const void *)model, idx + 1);
+            return SP_LLAMA_ROLE_DEFAULT;
+    }
+}
+
+extern "C" void llama_sp_maybe_init(const struct llama_model * model, int n_ctx) {
+    if (model == nullptr) return;
+
+    {
+        std::lock_guard<std::mutex> lk(g_sp_map_mtx);
+        if (g_sp_map.count(model)) return;   // already initialised for this model
+    }
+
+    const auto & hp = model->hparams;
+
+    const int head_dim   = (int)hp.n_embd_head_k_full;
+    const int n_layers   = (int)hp.n_layer;
+    const int n_heads_kv = (int)hp.n_head_kv(0);
+    const int max_seq    = n_ctx > 16 ? n_ctx : 16;
+
+    if (head_dim <= 0 || n_layers <= 0 || n_heads_kv <= 0) {
+        std::fprintf(stderr,
+            "[Shannon-Prime] skipping init: invalid hparams (hd=%d nl=%d nhkv=%d)\n",
+            head_dim, n_layers, n_heads_kv);
+        return;
+    }
+
+    // Build the new state in a local; insert into the map only on success.
+    sp_per_model st;
+    st.head_dim_k = head_dim;
+    st.head_dim_v = (int)hp.n_embd_head_v_full;
+    st.n_layers   = n_layers;
+    st.n_heads_kv = n_heads_kv;
+
+    // Resolve role under the map mutex so the counter increments
+    // monotonically with map insertions.
+    sp_llama_role_t role;
+    {
+        std::lock_guard<std::mutex> lk(g_sp_map_mtx);
+        role = resolve_init_role(model);
+    }
+
+    // --- Sqfree+spinor aggressive path --------------------------------------
+    const char * sqfree_env = std::getenv("SHANNON_PRIME_SQFREE");
+    if (sqfree_env && sqfree_env[0] == '1') {
+        sp_config_t cfg;
+        sp_config_init(&cfg, head_dim, n_layers, n_heads_kv);
+
+        // Parse K_BITS from env (e.g. "3,3,3,3,3"). Defaults to 5,4,4,4,5.
+        const char * kb = std::getenv("SHANNON_PRIME_K_BITS");
+        if (kb) {
+            int n = 0;
+            const char * p = kb;
+            while (*p && n < SP_MAX_BANDS) {
+                cfg.k_band_bits[n++] = atoi(p);
+                while (*p && *p != ',') p++;
+                if (*p == ',') p++;
+            }
+            cfg.k_n_bands = n;
+        } else {
+            cfg.k_n_bands       = 5;
+            cfg.k_band_bits[0]  = 5;
+            cfg.k_band_bits[1]  = 4;
+            cfg.k_band_bits[2]  = 4;
+            cfg.k_band_bits[3]  = 4;
+            cfg.k_band_bits[4]  = 5;
+        }
+        // V mirrors K under sqfree (cross-attn style, no RoPE asymmetry).
+        cfg.v_n_bands = cfg.k_n_bands;
+        std::memcpy(cfg.v_band_bits, cfg.k_band_bits,
+                    sizeof(int) * (size_t)cfg.k_n_bands);
+
+        const char * rb_env = std::getenv("SHANNON_PRIME_RESIDUAL_BITS");
+        int residual_bits = rb_env ? atoi(rb_env) : 3;
+        if (residual_bits < 1) residual_bits = 1;
+        if (residual_bits > 4) residual_bits = 4;
+
+        const char * spinor_env = std::getenv("SHANNON_PRIME_SPINOR");
+        const bool use_spinor = spinor_env && spinor_env[0] == '1';
+
+        int rc = sp_sqfree_cache_init(&st.sqfree_cache, &cfg,
+                                      max_seq, residual_bits, use_spinor);
+        if (rc != 0) {
+            std::fprintf(stderr,
+                "[Shannon-Prime SQFREE] init failed (rc=%d); falling back to WHT\n", rc);
+        } else {
+            st.sqfree_active = true;
+            std::fprintf(stderr,
+                "[Shannon-Prime SQFREE] active: model=%p hd=%d pad_dim=%d "
+                "n_layers=%d n_heads_kv=%d residual_bits=%d spinor=%s\n",
+                (const void *)model, head_dim, st.sqfree_cache.pad_dim,
+                n_layers, n_heads_kv, residual_bits, use_spinor ? "on" : "off");
+
+            std::lock_guard<std::mutex> lk(g_sp_map_mtx);
+            g_sp_map.emplace(model, std::move(st));
+            return;
+        }
+    }
+
+    // --- WHT ship path (default) --------------------------------------------
+    sp_llama_params_t params = {};
+    params.head_dim    = head_dim;
+    params.n_layers    = n_layers;
+    params.n_heads_kv  = n_heads_kv;
+    params.max_seq_len = max_seq;
+    params.backend     = decltype(params.backend)(0); // SP_BACKEND_CPU; env override in sp_llama_init
+    params.gpu_context = nullptr;
+
+    st.ctx = sp_llama_init_with_role(&params, role);
+    if (st.ctx == nullptr) return;
+
+    const char * role_tag =
+        (role == SP_LLAMA_ROLE_DRAFT)  ? " [draft]"  :
+        (role == SP_LLAMA_ROLE_TARGET) ? " [target]" : "";
+    std::fprintf(stderr,
+        "[Shannon-Prime]%s enabled: model=%p head_dim_k=%d head_dim_v=%d "
+        "n_layers=%d n_heads_kv=%d n_ctx=%d\n",
+        role_tag, (const void *)model,
+        st.head_dim_k, st.head_dim_v, st.n_layers, st.n_heads_kv, params.max_seq_len);
+
+    std::lock_guard<std::mutex> lk(g_sp_map_mtx);
+    g_sp_map.emplace(model, std::move(st));
+}
+
+extern "C" void llama_sp_free(const struct llama_model * model) {
+    if (!model) return;
+    sp_per_model removed;
+    bool found = false;
+    {
+        std::lock_guard<std::mutex> lk(g_sp_map_mtx);
+        auto it = g_sp_map.find(model);
+        if (it != g_sp_map.end()) {
+            removed = std::move(it->second);
+            g_sp_map.erase(it);
+            found = true;
+        }
+    }
+    // Drop the C-level resources outside the map mutex to keep teardown
+    // off the lock — these calls can be slow (file handles, GPU sync).
+    if (found) {
+        if (removed.ctx) sp_llama_free(removed.ctx);
+        if (removed.sqfree_active) sp_sqfree_cache_free(&removed.sqfree_cache);
+    }
+}
+
+extern "C" void llama_sp_free_all(void) {
+    std::vector<sp_per_model> drained;
+    {
+        std::lock_guard<std::mutex> lk(g_sp_map_mtx);
+        drained.reserve(g_sp_map.size());
+        for (auto & kv : g_sp_map) drained.push_back(std::move(kv.second));
+        g_sp_map.clear();
+        g_sp_init_counter.store(0, std::memory_order_relaxed);
+    }
+    for (auto & st : drained) {
+        if (st.ctx) sp_llama_free(st.ctx);
+        if (st.sqfree_active) sp_sqfree_cache_free(&st.sqfree_cache);
+    }
+}
+
+extern "C" bool llama_sp_is_enabled(const struct llama_model * model) {
+    const sp_per_model * st = sp_state_for(model);
+    return st != nullptr && (st->ctx != nullptr || st->sqfree_active);
+}
+
+// Helpers for the sidecar apply path.
+namespace {
+
+// Load `path` (must exist) into `out` as fp32 entries. Returns number of
+// fp32 entries read; 0 on any failure.
+size_t load_sidecar_fp32(const char * path, std::vector<float> & out) {
+    std::FILE * fp = std::fopen(path, "rb");
+    if (!fp) return 0;
+    std::fseek(fp, 0, SEEK_END);
+    long sz = std::ftell(fp);
+    std::fseek(fp, 0, SEEK_SET);
+    if (sz <= 0 || (sz % (long)sizeof(float)) != 0) {
+        std::fclose(fp);
+        return 0;
+    }
+    size_t n = (size_t)sz / sizeof(float);
+    out.resize(n);
+    size_t got = std::fread(out.data(), sizeof(float), n, fp);
+    std::fclose(fp);
+    return got;
+}
+
+// Pick the rope-factor tensor a layer prefers: rope_freqs > rope_long > rope_short.
+// Mirrors the preference order in llama_model::get_rope_factors.
+ggml_tensor * pick_rope_tensor(const llama_layer & layer) {
+    if (layer.rope_freqs) return layer.rope_freqs;
+    if (layer.rope_long)  return layer.rope_long;
+    if (layer.rope_short) return layer.rope_short;
+    return nullptr;
+}
+
+} // namespace
+
+// Shared: write freq_factors into all rope tensors across model layers.
+// factors must point to n_factors floats. alpha blends against existing values.
+static void apply_rope_factors(const struct llama_model * model,
+                               const float * factors, size_t n_factors,
+                               float alpha, const char * source_tag) {
+    int patched  = 0;
+    int skipped  = 0;
+    int mismatch = 0;
+    std::vector<float> scratch;
+
+    for (size_t il = 0; il < model->layers.size(); il++) {
+        ggml_tensor * t = pick_rope_tensor(model->layers[il]);
+        if (!t) { skipped++; continue; }
+        // Skip tensors whose backend buffer isn't bound yet (e.g. graph-time
+        // scratch tensors that look real but have no host/device data).
+        // ggml_backend_tensor_set would assert on null data.
+        if (!t->buffer || !t->data) { skipped++; continue; }
+        if ((size_t)t->ne[0] != n_factors || t->ne[1] != 1 || t->type != GGML_TYPE_F32) {
+            if (mismatch == 0) {
+                std::fprintf(stderr,
+                    "[Shannon-Prime] %s layout mismatch at layer %zu: "
+                    "tensor ne=[%lld,%lld,%lld,%lld] type=%d, factors n=%zu — skipping\n",
+                    source_tag, il, (long long)t->ne[0], (long long)t->ne[1],
+                    (long long)t->ne[2], (long long)t->ne[3], (int)t->type, n_factors);
+            }
+            mismatch++;
+            continue;
+        }
+
+        if (alpha == 1.0f) {
+            ggml_backend_tensor_set(t, factors, 0, n_factors * sizeof(float));
+        } else {
+            scratch.resize(n_factors);
+            ggml_backend_tensor_get(t, scratch.data(), 0, n_factors * sizeof(float));
+            for (size_t i = 0; i < n_factors; i++) {
+                scratch[i] = (1.0f - alpha) * scratch[i] + alpha * factors[i];
+            }
+            ggml_backend_tensor_set(t, scratch.data(), 0, n_factors * sizeof(float));
+        }
+        patched++;
+    }
+
+    std::fprintf(stderr,
+        "[Shannon-Prime] %s applied: alpha=%.3f n_freqs=%zu "
+        "patched=%d skipped=%d mismatched=%d\n",
+        source_tag, alpha, n_factors, patched, skipped, mismatch);
+}
+
+extern "C" void llama_sp_maybe_apply_rope_sidecar(const struct llama_model * model) {
+    if (!model) return;
+
+    // Priority 1: explicit sidecar file (pre-baked factors from sp_inject_freqs.py)
+    const char * sidecar_env = std::getenv("SHANNON_PRIME_SIDECAR");
+    if (sidecar_env && *sidecar_env) {
+        std::vector<float> sidecar;
+        size_t n_sidecar = load_sidecar_fp32(sidecar_env, sidecar);
+        if (n_sidecar == 0) {
+            std::fprintf(stderr,
+                "[Shannon-Prime] sidecar '%s' unreadable or empty — skipping\n",
+                sidecar_env);
+            return;
+        }
+
+        const char * alpha_env = std::getenv("SHANNON_PRIME_ALPHA");
+        float alpha = alpha_env ? (float)std::atof(alpha_env) : 1.0f;
+        if (alpha < 0.0f) alpha = 0.0f;
+        if (alpha > 1.0f) alpha = 1.0f;
+
+        apply_rope_factors(model, sidecar.data(), n_sidecar, alpha, "sidecar");
+        return;
+    }
+
+    // Priority 2: live-computed PrimePE factors from sp_llama_init()
+    // These are lattice-aligned freq_factors computed at context creation.
+    // No sidecar file needed — zero user action required. Per-model: each
+    // model has its own SP context with its own freq_factors.
+    const sp_per_model * st = sp_state_for(model);
+    if (st && st->ctx) {
+        const float * factors = sp_llama_get_freq_factors(st->ctx);
+        int n_freqs = sp_llama_get_n_freqs(st->ctx);
+        if (factors && n_freqs > 0) {
+            apply_rope_factors(model, factors, (size_t)n_freqs, 1.0f, "PrimePE");
+            return;
+        }
+    }
+
+    // Neither path active — no-op (standard geometric RoPE unchanged)
+}
+
+extern "C" void llama_sp_post_compute(const struct llama_model * model,
+                                      const struct llama_memory_context_i * mctx,
+                                      const struct llama_ubatch * ubatch,
+                                      int max_bands) {
+    if (!model || !mctx || !ubatch) return;
+    const sp_per_model * st = sp_state_for(model);
+    if (!st || (!st->ctx && !st->sqfree_active)) return;
+
+    // Phase 3 work item 2: max_bands is now actually used. The shadow
+    // (WHT) reads dispatch through sp_llama_read_{k,v}_partial which
+    // calls sp_band_dequantize_partial under the hood. When
+    // max_bands >= n_bands the partial path is byte-identical to the
+    // full path (it just returns early on the band-loop bound check),
+    // so this is fully backward-compatible. The sqfree path doesn't
+    // have a partial implementation yet — sqfree reads keep using
+    // the full sp_sqfree_read_{k,v} routines.
+    static std::atomic<bool> max_bands_logged{false};
+    bool expected = false;
+    if (max_bands_logged.compare_exchange_strong(expected, true)) {
+        const char * verbose = std::getenv("SHANNON_PRIME_VERBOSE");
+        if (verbose && verbose[0] == '1') {
+            std::fprintf(stderr,
+                "[Shannon-Prime] post_compute: max_bands=%d (partial dispatch "
+                "active when < n_bands; sqfree path always full)\n", max_bands);
+        }
+    }
+    // Snapshot the C-level pointers so the inner loop doesn't re-lock
+    // through sp_state_for() per iteration. Pointers to the map's stored
+    // sqfree_cache and ctx remain valid for as long as this entry exists,
+    // which is for the duration of the owning llama_context's lifetime —
+    // i.e., longer than any post_compute call.
+    sp_llama_ctx_t *  sp_ctx        = st->ctx;
+    sp_sqfree_cache_t * sqfree_cache = const_cast<sp_sqfree_cache_t *>(&st->sqfree_cache);
+    const bool        sqfree_active = st->sqfree_active;
+
+    // Diagnostic toggles. SHANNON_PRIME_SKIP_K / SKIP_V can bypass one side
+    // of the round-trip for isolating which half is responsible for a
+    // quality regression.
+    static const char * sk_env  = std::getenv("SHANNON_PRIME_SKIP_K");
+    static const char * sv_env  = std::getenv("SHANNON_PRIME_SKIP_V");
+    static const bool   skip_k  = sk_env && sk_env[0] == '1';
+    static const bool   skip_v  = sv_env && sv_env[0] == '1';
+
+    // Only the unified KV cache path is handled. ISWA / hybrid caches are
+    // out of scope for the first post-decode hook iteration.
+    auto * kvc = dynamic_cast<const llama_kv_cache_context *>(mctx);
+    if (!kvc) return;
+
+    auto * kv = kvc->get_kv();
+    if (!kv) return;
+
+    const auto & sinfos_vec = kvc->get_cur_sinfo();
+    if (sinfos_vec.empty()) return;
+    const auto & sinfo = sinfos_vec[kvc->get_cur_idx()];
+    const auto & layers = kv->get_layers();
+    const int n_tokens  = (int)ubatch->n_tokens;
+    if (n_tokens <= 0) return;
+    if (sinfo.idxs.empty() || sinfo.idxs[0].empty()) return;
+
+    const int hd_k = st->head_dim_k;
+    const int hd_v = st->head_dim_v;
+    const int nhk  = st->n_heads_kv;
+
+    // One-shot diagnostic: log what V path we're taking so we can tell
+    // contiguous-per-position from the v_trans strided variant apart.
+    static std::atomic<bool> vpath_logged{false};
+    if (!layers.empty() && layers[0].v) {
+        bool expected = false;
+        if (vpath_logged.compare_exchange_strong(expected, true)) {
+            bool vcp = (size_t)layers[0].v->nb[1] <= (size_t)layers[0].v->nb[2];
+            std::fprintf(stderr,
+                "[Shannon-Prime] V path: %s (v->nb[1]=%zu, v->nb[2]=%zu) skip_k=%d skip_v=%d\n",
+                vcp ? "CONTIGUOUS-PER-POS" : "STRIDED-V_TRANS",
+                (size_t)layers[0].v->nb[1], (size_t)layers[0].v->nb[2],
+                skip_k ? 1 : 0, skip_v ? 1 : 0);
+        }
+    }
+
+    float * gather = get_scratch(tl_gather, (size_t)(hd_k > hd_v ? hd_k : hd_v));
+    float * recon  = get_scratch(tl_recon,  (size_t)(hd_k > hd_v ? hd_k : hd_v));
+
+    // Walk each kv layer × each newly-written position × each head.
+    // Round-trip K always. Round-trip V only when v_trans=false so the
+    // per-position per-head vector is contiguous in memory. When v_trans
+    // is true (default), V lives in [head_dim, head, position] order with
+    // position innermost — gather/scatter would need strided access per
+    // element; deferred.
+    for (size_t ikv = 0; ikv < layers.size(); ++ikv) {
+        const auto & L = layers[ikv];
+        ggml_tensor * k = L.k;
+        ggml_tensor * v = L.v;
+        if (!k) continue;
+        // k->data is only populated for host-resident tensors; for device
+        // buffers the actual storage is behind ggml_backend_tensor_*. Use
+        // the presence of any bound buffer as the liveness check.
+        if (!k->buffer && !k->data) continue;
+
+        const ggml_type tk = k->type;
+        const size_t    ek = ggml_type_size(tk);
+        const size_t    n_embd_k_gqa = (size_t)k->ne[0]; // head_dim * nhk
+        // Defensive: if the cache's head layout doesn't match what we
+        // initialised against, skip this layer rather than crash.
+        if (n_embd_k_gqa != (size_t)hd_k * (size_t)nhk) continue;
+        const size_t k_pos_stride = n_embd_k_gqa * ek;
+
+        const int il = (int)L.il;
+
+        // Slot 0 in the shadow cache is scratch for round-trip only (we
+        // don't use it as a long-term store here — the live KV cache IS
+        // the store; Shannon-Prime only lends its compress/decompress).
+        // k may live on a device buffer (-ngl 99 without -nkvo) — gather/
+        // scatter route through ggml_backend_tensor_{get,set} in that case.
+
+        if (skip_k) goto do_v;
+
+        // SHANNON_PRIME_DUMP_K=<path> appends raw K vectors (hd_k × fp32) to
+        // <path>; tools/sp_auto_bands.py consumes the dump to compute a per-band
+        // VHT2 energy-weighted bit allocation. Opened once, stream-writes,
+        // closed at process exit (OS cleans up). Hard cap via LIMIT env so we
+        // don't blow up a warmup run into gigabytes.
+        static std::FILE * dump_fp = nullptr;
+        static long long   dump_count = 0;
+        static long long   dump_limit = 0;
+        static std::atomic<bool> dump_init{false};
+        if (!dump_init.exchange(true)) {
+            const char * dp = std::getenv("SHANNON_PRIME_DUMP_K");
+            if (dp && *dp) {
+                dump_fp = std::fopen(dp, "wb");
+                const char * lim_s = std::getenv("SHANNON_PRIME_DUMP_K_LIMIT");
+                dump_limit = lim_s ? std::atoll(lim_s) : 8192;
+                std::fprintf(stderr,
+                    "[Shannon-Prime] K dump → %s (limit=%lld vectors, hd=%d)\n",
+                    dp, dump_limit, hd_k);
+            }
+        }
+
+        {
+        // PREFILL FAST PATH — batched compress_f32_batch FastRPC (when applicable).
+        // Reduces n_tokens × nhk × 2 single-position FastRPC calls to nhk × 2
+        // batched calls per layer at prefill (n_tokens > 1). Falls back to the
+        // per-position path for: sqfree codec (host-only memcpy, no FastRPC win),
+        // partial-fidelity reads (max_bands >= 0, batched read returns full bands
+        // only), or single-token generation (chunk=1 has no batching benefit).
+        // Batch covers full-fidelity reads only: max_bands < 0 (explicit "all") OR
+        // max_bands >= 4 (i.e., asking for >= n_bands of K, which the math core treats
+        // as "all" — INT_MAX is the no-partial-dispatch default value).
+        const bool use_k_batch = !sqfree_active && n_tokens > 1 &&
+                                 (max_bands < 0 || max_bands >= 4);
+
+        if (use_k_batch) {
+            // Per-head batch buffers, reused across heads. Each is
+            // n_tokens * hd_k floats. At n_tokens=2000, hd_k=128: ~1 MB
+            // per buffer × 2 = 2 MB peak — acceptable on phone.
+            std::vector<float>   batch_in ((size_t)n_tokens * (size_t)hd_k);
+            std::vector<float>   batch_out((size_t)n_tokens * (size_t)hd_k);
+            std::vector<uint8_t> valid    (n_tokens, 0);
+
+            for (int h = 0; h < nhk; ++h) {
+                bool any_valid = false;
+                for (int t = 0; t < n_tokens; ++t) {
+                    uint32_t slot = sinfo.idxs[0][t];
+                    const size_t off = (size_t)slot * k_pos_stride + (size_t)h * hd_k * ek;
+                    float * dst = batch_in.data() + (size_t)t * hd_k;
+                    valid[t] = gather_vec(k, off, hd_k, dst) ? 1 : 0;
+                    if (valid[t]) {
+                        any_valid = true;
+                        if (dump_fp && (dump_limit == 0 || dump_count < dump_limit)) {
+                            std::fwrite(dst, sizeof(float), hd_k, dump_fp);
+                            dump_count++;
+                            if (dump_count == dump_limit) std::fflush(dump_fp);
+                        }
+                    } else {
+                        // Zero-fill so DSP doesn't see uninitialised data.
+                        std::memset(dst, 0, sizeof(float) * hd_k);
+                    }
+                }
+                if (!any_valid) continue;
+
+                // Single batched compress + decompress at slots [0..n_tokens-1].
+                // The bridge chunks internally (SP_HEX_BATCH_CHUNK, default 32);
+                // FastRPC dispatches per (layer, head) becomes ceil(n_tokens / chunk).
+                sp_llama_write_k_batch(sp_ctx, il, h, (int)sinfo.idxs[0][0], n_tokens, batch_in.data());
+                sp_llama_read_k_batch (sp_ctx, il, h, (int)sinfo.idxs[0][0], n_tokens, batch_out.data());
+
+                // Scatter only valid positions; invalid retain original K.
+                for (int t = 0; t < n_tokens; ++t) {
+                    if (!valid[t]) continue;
+                    uint32_t slot = sinfo.idxs[0][t];
+                    const size_t off = (size_t)slot * k_pos_stride + (size_t)h * hd_k * ek;
+                    scatter_vec(k, off, hd_k, batch_out.data() + (size_t)t * hd_k);
+                }
+            }
+        } else {
+            // Per-position fallback: sqfree, partial-fidelity, or single-tok gen.
+            for (int t = 0; t < n_tokens; ++t) {
+                uint32_t slot = sinfo.idxs[0][t];
+                const size_t pos_off = (size_t)slot * k_pos_stride;
+
+                for (int h = 0; h < nhk; ++h) {
+                    const size_t off = pos_off + (size_t)h * hd_k * ek;
+                    if (!gather_vec(k, off, hd_k, gather)) continue;
+
+                    if (dump_fp && (dump_limit == 0 || dump_count < dump_limit)) {
+                        std::fwrite(gather, sizeof(float), hd_k, dump_fp);
+                        dump_count++;
+                        if (dump_count == dump_limit) std::fflush(dump_fp);
+                    }
+
+                    if (sqfree_active) {
+                        sp_sqfree_write_k(sqfree_cache, il, h, 0, gather);
+                        sp_sqfree_read_k (sqfree_cache, il, h, 0, recon);
+                    } else {
+                        sp_llama_write_k        (sp_ctx, il, h, (int)slot, gather);
+                        sp_llama_read_k_partial (sp_ctx, il, h, (int)slot, recon, max_bands);
+                    }
+
+                    scatter_vec(k, off, hd_k, recon);
+                }
+            }
+        }
+        }
+
+        // V — only when not transposed. The adjacency check matches
+        // llama_kv_cache::get_v's v_trans=false branch.
+        do_v:
+        if (skip_v) continue;
+        if (v && (v->buffer || v->data)) {
+            const ggml_type tv = v->type;
+            const size_t    ev = ggml_type_size(tv);
+            // When v_trans is false, v->nb[1] == row_size(head_dim)
+            // and positions live at v->nb[2]. When v_trans is true,
+            // v->nb[1] > v->nb[2] (positions innermost).
+            const bool v_contig_per_pos = (size_t)v->nb[1] <= (size_t)v->nb[2];
+
+            if (v_contig_per_pos) {
+                const size_t n_embd_v_gqa = (size_t)v->ne[0]; // head_dim * nhk
+                if (n_embd_v_gqa == (size_t)hd_v * (size_t)nhk) {
+                    const size_t v_pos_stride = n_embd_v_gqa * ev;
+
+                    // V PREFILL FAST PATH — mirror K-batch logic for V.
+                    // V has 1 band, so "all bands" = max_bands < 0 OR >= 1.
+                    const bool use_v_batch = !sqfree_active && n_tokens > 1 &&
+                                             (max_bands < 0 || max_bands >= 1);
+                    if (use_v_batch) {
+                        std::vector<float>   v_batch_in ((size_t)n_tokens * (size_t)hd_v);
+                        std::vector<float>   v_batch_out((size_t)n_tokens * (size_t)hd_v);
+                        std::vector<uint8_t> v_valid    (n_tokens, 0);
+                        for (int h = 0; h < nhk; ++h) {
+                            bool any_valid = false;
+                            for (int t = 0; t < n_tokens; ++t) {
+                                uint32_t slot = sinfo.idxs[0][t];
+                                const size_t off = (size_t)slot * v_pos_stride + (size_t)h * hd_v * ev;
+                                float * dst = v_batch_in.data() + (size_t)t * hd_v;
+                                v_valid[t] = gather_vec(v, off, hd_v, dst) ? 1 : 0;
+                                if (v_valid[t]) any_valid = true;
+                                else std::memset(dst, 0, sizeof(float) * hd_v);
+                            }
+                            if (!any_valid) continue;
+                            sp_llama_write_v_batch(sp_ctx, il, h, (int)sinfo.idxs[0][0], n_tokens, v_batch_in.data());
+                            sp_llama_read_v_batch (sp_ctx, il, h, (int)sinfo.idxs[0][0], n_tokens, v_batch_out.data());
+                            for (int t = 0; t < n_tokens; ++t) {
+                                if (!v_valid[t]) continue;
+                                uint32_t slot = sinfo.idxs[0][t];
+                                const size_t off = (size_t)slot * v_pos_stride + (size_t)h * hd_v * ev;
+                                scatter_vec(v, off, hd_v, v_batch_out.data() + (size_t)t * hd_v);
+                            }
+                        }
+                    } else {
+                    for (int t = 0; t < n_tokens; ++t) {
+                        uint32_t slot = sinfo.idxs[0][t];
+                        const size_t pos_off = (size_t)slot * v_pos_stride;
+
+                        for (int h = 0; h < nhk; ++h) {
+                            const size_t off = pos_off + (size_t)h * hd_v * ev;
+                            if (!gather_vec(v, off, hd_v, gather)) continue;
+
+                            if (sqfree_active) {
+                                sp_sqfree_write_v(sqfree_cache, il, h, 0, gather);
+                                sp_sqfree_read_v (sqfree_cache, il, h, 0, recon);
+                            } else {
+                                sp_llama_write_v        (sp_ctx, il, h, (int)slot, gather);
+                                sp_llama_read_v_partial (sp_ctx, il, h, (int)slot, recon, max_bands);
+                            }
+
+                            scatter_vec(v, off, hd_v, recon);
+                        }
+                    }
+                    }
+                }
+            } else {
+                // v_trans=true path: storage layout is
+                //   v[stream, head, head_dim_idx, position]
+                // with `position` innermost (stride = element_size),
+                // `head_dim_idx` at stride kv_size elements,
+                // `head`        at stride kv_size*head_dim elements.
+                // So for a fixed (head h, position p) the hd floats that
+                // make up the V vector live at a *strided* set of offsets.
+                // We gather hd elements into a contiguous scratch, run the
+                // shannon-prime round-trip, scatter back.
+                const size_t n_embd_v_gqa = (size_t)v->ne[0]; // head_dim * nhk
+                // The v_trans=true path does per-element strided access
+                // directly via v->data; that's only valid when V lives on a
+                // host buffer. Skip silently on device buffers — a GPU
+                // v_trans=true compressor needs its own kernel (deferred).
+                if (v->buffer && !ggml_backend_buffer_is_host(v->buffer)) {
+                    goto next_layer;
+                }
+                if (n_embd_v_gqa == (size_t)hd_v * (size_t)nhk) {
+                    const uint32_t kv_size = kv->get_size();
+                    const size_t   head_stride_elts  = (size_t)kv_size * hd_v;  // elements between heads
+                    const size_t   inner_stride_elts = (size_t)kv_size;          // elements between head_dim indices
+                    uint8_t *      vdata = (uint8_t *)v->data;
+
+                    for (int t = 0; t < n_tokens; ++t) {
+                        uint32_t slot = sinfo.idxs[0][t];
+                        const size_t slot_off_elts = (size_t)slot;
+
+                        for (int h = 0; h < nhk; ++h) {
+                            const size_t head_off_elts = (size_t)h * head_stride_elts;
+
+                            // Gather hd strided floats from the cache.
+                            if (tv == GGML_TYPE_F32) {
+                                const float * vp = (const float *)vdata;
+                                for (int i = 0; i < hd_v; ++i) {
+                                    gather[i] = vp[head_off_elts + (size_t)i * inner_stride_elts + slot_off_elts];
+                                }
+                            } else if (tv == GGML_TYPE_F16) {
+                                const ggml_fp16_t * vp = (const ggml_fp16_t *)vdata;
+                                for (int i = 0; i < hd_v; ++i) {
+                                    gather[i] = ggml_fp16_to_fp32(vp[head_off_elts + (size_t)i * inner_stride_elts + slot_off_elts]);
+                                }
+                            } else {
+                                continue;
+                            }
+
+                            if (sqfree_active) {
+                                sp_sqfree_write_v(sqfree_cache, il, h, 0, gather);
+                                sp_sqfree_read_v (sqfree_cache, il, h, 0, recon);
+                            } else {
+                                sp_llama_write_v        (sp_ctx, il, h, (int)slot, gather);
+                                sp_llama_read_v_partial (sp_ctx, il, h, (int)slot, recon, max_bands);
+                            }
+
+                            // Scatter the reconstructed values back to the
+                            // same strided locations.
+                            if (tv == GGML_TYPE_F32) {
+                                float * vp = (float *)vdata;
+                                for (int i = 0; i < hd_v; ++i) {
+                                    vp[head_off_elts + (size_t)i * inner_stride_elts + slot_off_elts] = recon[i];
+                                }
+                            } else if (tv == GGML_TYPE_F16) {
+                                ggml_fp16_t * vp = (ggml_fp16_t *)vdata;
+                                for (int i = 0; i < hd_v; ++i) {
+                                    vp[head_off_elts + (size_t)i * inner_stride_elts + slot_off_elts] = ggml_fp32_to_fp16(recon[i]);
+                                }
+                            }
+                        }
+                    }
+                }
+            }
+        }
+        next_layer:;
+    }
+}
+
+#endif // LLAMA_SHANNON_PRIME
diff --git a/src/llama-shannon-prime.h b/src/llama-shannon-prime.h
new file mode 100644
index 0000000..071b73c
--- /dev/null
+++ b/src/llama-shannon-prime.h
@@ -0,0 +1,100 @@
+// Shannon-Prime VHT2 KV cache compression hooks for llama.cpp.
+//
+// Activated when SHANNON_PRIME_ENABLED=1 is set in the environment.
+// Hook strategy: a post-graph_compute callback that walks the freshly-
+// written slots of the llama KV cache (layers[il].k / .v) and round-trips
+// their data through the Shannon-Prime compressed shadow cache in place.
+// Attention later reads the cache tensors directly, so seeing
+// reconstructed-from-compressed values. Single sync per decode call
+// instead of per-tensor — avoids the ggml_backend_sched eval-callback
+// serialization that killed throughput on mobile.
+//
+// CPU-only. Handles fp32 and fp16 KV cache types; other types are
+// passed through untouched (one-shot warning).
+
+#pragma once
+
+#ifdef LLAMA_SHANNON_PRIME
+
+#include <stdbool.h>
+#include "ggml.h"
+
+struct llama_model;
+struct llama_ubatch;
+struct llama_memory_context_i;
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+// Lazily initialise a per-model Shannon-Prime context from model hparams +
+// environment variables. No-op if this model is already initialised or if
+// SHANNON_PRIME_ENABLED is not set.
+//
+// State is keyed on the `model` pointer — every llama_context that wraps a
+// distinct llama_model gets its own SP context, dimensions, and shadow
+// cache. This is what lets speculative decoding (-md) compress both the
+// target and the draft cleanly: each model has independent K/V dims and
+// an independent SP compression policy.
+//
+// Role detection (target vs draft) for differential compression is
+// opt-in via SHANNON_PRIME_SPEC=1 in the environment. When set, the
+// first model initialised gets SP_LLAMA_ROLE_TARGET and the second
+// gets SP_LLAMA_ROLE_DRAFT — matching llama.cpp's deterministic init
+// order under -md (target first, draft second). Third+ models fall
+// back to ROLE_DEFAULT with a warning. When SHANNON_PRIME_SPEC is
+// unset, every model gets ROLE_DEFAULT — preserves all existing
+// single-model behaviour.
+void llama_sp_maybe_init(const struct llama_model * model, int n_ctx);
+
+// Apply lattice-aligned RoPE frequency factors to model rope tensors.
+// Two sources, in priority order:
+//   1. SHANNON_PRIME_SIDECAR=<path>  — pre-baked .sp_freq_factors.bin file
+//      (optional: SHANNON_PRIME_ALPHA=0..1, default 1)
+//   2. Live-computed PrimePE factors from sp_llama_init() context
+//      (automatic when SHANNON_PRIME_ENABLED=1, controlled by
+//       SHANNON_PRIME_PE=1 and SHANNON_PRIME_PE_ALPHA=0.17)
+// Safe no-op when neither source is active, or no layer has a
+// rope_freqs / rope_long / rope_short tensor. Called once after model load.
+void llama_sp_maybe_apply_rope_sidecar(const struct llama_model * model);
+
+// Tear down a single model's SP context (called from ~llama_context).
+// Idempotent — passing a model that was never initialised is a no-op.
+void llama_sp_free(const struct llama_model * model);
+
+// Tear down all SP contexts (called on llama_backend_free or shutdown).
+// Idempotent.
+void llama_sp_free_all(void);
+
+// True iff Shannon-Prime is active for this model.
+bool llama_sp_is_enabled(const struct llama_model * model);
+
+// Post-decode hook. Called from llama_context::process_ubatch right after
+// graph_compute returns successfully. Walks the KV cache tensor storage
+// for the positions just written by this ubatch, round-trips K (and V
+// when its layout is contiguous per-position) through the Shannon-Prime
+// shadow cache for the GIVEN MODEL, and writes the reconstructed values
+// back in place. The model pointer disambiguates target vs. draft when
+// multiple models share a process (speculative decoding).
+//
+// max_bands clamps how many spectral bands of the SP cache get used in
+// the round-trip. INT_MAX (or any value >= n_bands) reads all bands —
+// the default and sp1/sp2 behaviour. Smaller values trade reconstruction
+// fidelity for read bandwidth, intended for the phase-3 attention
+// short-circuit. Today the parameter is plumbed through but the
+// dequantize itself still reads all bands; wiring sp_band_dequantize_partial
+// into sp_llama_read_k is the next work item (phase 3 work item 2).
+//
+// The caller-side env var SHANNON_PRIME_DEFAULT_BANDS resolves to a
+// max_bands value for callers that don't compute one dynamically.
+// Empty / unset = INT_MAX = full read.
+void llama_sp_post_compute(const struct llama_model * model,
+                           const struct llama_memory_context_i * mctx,
+                           const struct llama_ubatch * ubatch,
+                           int max_bands);
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif // LLAMA_SHANNON_PRIME
