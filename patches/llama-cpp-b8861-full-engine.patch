+
+        # FP8/FP4 kernels (opt-in: -DSP_FP8=ON, requires sm_89+/sm_120+ and CUDA >= 12.8)
+        option(SP_FP8 "Enable FP8 E4M3FN + FP4 MXFP4 CUDA kernels" OFF)
+        if (SP_FP8)
+            list(APPEND _SP_CUDA_SOURCES ${_SP_BACK}/cuda/shannon_prime_fp8.cu)
+            message(STATUS "Shannon-Prime: FP8/FP4 CUDA kernels enabled (SP_FP8)")
+        endif()
+
+        add_library(shannon_prime_cuda STATIC ${_SP_CUDA_SOURCES})
+        target_include_directories(shannon_prime_cuda PUBLIC ${_SP_INCLUDES})
+        target_compile_definitions(shannon_prime_cuda PUBLIC LLAMA_SHANNON_PRIME SP_HAVE_CUDA)
+        set_property(TARGET shannon_prime_cuda PROPERTY POSITION_INDEPENDENT_CODE ON)
+        if (CMAKE_CUDA_ARCHITECTURES)
+            set_property(TARGET shannon_prime_cuda PROPERTY CUDA_ARCHITECTURES "${CMAKE_CUDA_ARCHITECTURES}")
+        else()
+            set_property(TARGET shannon_prime_cuda PROPERTY CUDA_ARCHITECTURES "89")
+        endif()
+
+        target_compile_definitions(shannon_prime_core PUBLIC SP_HAVE_CUDA)
+        if (SP_FP8)
+            target_compile_definitions(shannon_prime_cuda PUBLIC SP_FP8=1 SP_FP4=1)
+            target_compile_definitions(shannon_prime_core PUBLIC SP_FP8=1 SP_FP4=1)
+        endif()
+        message(STATUS "Shannon-Prime: linking CUDA backends (SP_HAVE_CUDA)")
+    endif()
+
+    # --- Engine subsystems (C++) ---
+    set(_SP_ENGINE_SOURCES
+        ${_SP_ENG}/kv_cache.cpp
+        ${_SP_ENG}/gdn_state.cpp
+    )
+    add_library(shannon_prime_engine STATIC ${_SP_ENGINE_SOURCES})
+    target_include_directories(shannon_prime_engine PUBLIC
+        ${_SP_INCLUDES}
+        ${CMAKE_CURRENT_SOURCE_DIR}/../ggml/include
+    )
+    target_compile_definitions(shannon_prime_engine PUBLIC LLAMA_SHANNON_PRIME)
+    target_compile_features(shannon_prime_engine PRIVATE cxx_std_17)
+    set_property(TARGET shannon_prime_engine PROPERTY POSITION_INDEPENDENT_CODE ON)
+    target_link_libraries(shannon_prime_engine PUBLIC shannon_prime_core)
+    if (SP_CUDA)
+        target_link_libraries(shannon_prime_engine PUBLIC shannon_prime_cuda)
