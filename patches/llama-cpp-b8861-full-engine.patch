# Shannon-Prime llama.cpp patch — full engine (v2.1)
#
# Targets: llama.cpp b8861 (ggml-org/llama.cpp tag b8861, commit cf8b0db)
#          LM Studio v2.14.0 runtime (same base).
#
# This patch supersedes the b8733 patch. It integrates the complete
# Shannon-Prime engine: VHT2 core, sqfree+spinor, hierarchical KV cache,
# GDN state (System 1/2), CUDA/Vulkan/Adreno backends, model-pack registry.
#
# Sources are NOT vendored — the patch's CMakeLists references
# SHANNON_PRIME_DIR (your shannon-prime-llama checkout), which provides:
#   lib/shannon-prime/core/   — core math (submodule)
#   src/backends/             — CUDA, Vulkan, Adreno
#   src/engine/               — hierarchical cache, GDN state
#   src/tools/                — llama bridge helpers
#
# SP_CUDA is independent of GGML_CUDA: compile our .cu files without
# triggering ggml-cuda (works around MSVC 2019 template failures).
#
# Validated: Qwen3.6-35B-A3B at 26.92 tok/sec in LM Studio (b8733).
# Qwen 3.6 27B improved support in b8861.

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 310a3dc..061294a 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -33,6 +33,20 @@ endif()
 
 option(LLAMA_USE_SYSTEM_GGML "Use system libggml" OFF)
 
+# Shannon-Prime full engine — VHT2 + hierarchical cache + System 1/2 + multi-GPU.
+# ON by default: if you applied this patch, you want Shannon-Prime.
+# Set SHANNON_PRIME_DIR to your shannon-prime-llama checkout (auto-detected if
+# a sibling directory named shannon-prime-llama exists).
+option(LLAMA_SHANNON_PRIME "llama: enable Shannon-Prime engine (VHT2, hierarchical, System 1/2)" ON)
+if (NOT SHANNON_PRIME_DIR)
+    # Auto-detect: look for shannon-prime-llama as a sibling of this repo
+    if (EXISTS "${CMAKE_SOURCE_DIR}/../shannon-prime-llama/lib/shannon-prime/core/shannon_prime.h")
+        get_filename_component(SHANNON_PRIME_DIR "${CMAKE_SOURCE_DIR}/../shannon-prime-llama" ABSOLUTE)
+        message(STATUS "Shannon-Prime: auto-detected SHANNON_PRIME_DIR=${SHANNON_PRIME_DIR}")
+    endif()
+endif()
+set(SHANNON_PRIME_DIR "${SHANNON_PRIME_DIR}" CACHE PATH "Path to shannon-prime-llama checkout")
+
 option(LLAMA_WASM_MEM64 "llama: use 64-bit memory in WASM builds" ON)
 
 if (EMSCRIPTEN)
