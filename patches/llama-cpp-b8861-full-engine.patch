+    # Suppress warnings that llama.cpp's strict flags promote to errors
+    if (CMAKE_C_COMPILER_ID MATCHES "GNU|Clang")
+        target_compile_options(shannon_prime_core PRIVATE
+            -Wno-alloc-size-larger-than -Wno-cast-qual -Wno-overflow)
+    elseif (MSVC)
+        target_compile_options(shannon_prime_core PRIVATE /W3)
