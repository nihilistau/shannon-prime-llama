+            sp_kq_ud.n_kv                   = (int) k->ne[1];
+            sp_kq_ud.is_v                   = 0;
+            sp_kq_ud.k_packed_buf_per_head  = nullptr;
+            sp_kq_ud.total_bytes_per_pos    = 0;
+            kq = ggml_map_custom2(ctx0, q, k, llama_sp_kq_compute,
+                                  GGML_N_TASKS_MAX, &sp_kq_ud);
+        }
+#endif
+        if (!kq) kq = ggml_mul_mat(ctx0, k, q);
         cb(kq, "kq", il);
 
         // note: this op tends to require high floating point range
