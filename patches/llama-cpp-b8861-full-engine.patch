+    set_property(TARGET shannon_prime_engine PROPERTY POSITION_INDEPENDENT_CODE ON)
+    target_link_libraries(shannon_prime_engine PUBLIC shannon_prime_core)
+    if (SP_CUDA)
+        target_link_libraries(shannon_prime_engine PUBLIC shannon_prime_cuda)
+        target_compile_definitions(shannon_prime_engine PUBLIC SP_HAVE_CUDA SP_ENGINE_WITH_CUDA)
+        target_include_directories(shannon_prime_engine PRIVATE ${CMAKE_CUDA_TOOLKIT_INCLUDE_DIRECTORIES})
+    endif()
+
+    # --- Wire into llama ---
+    target_compile_definitions(llama PRIVATE ${_SP_DEFS})
