+if (LLAMA_SHANNON_PRIME)
+    # ========================================================================
+    # Shannon-Prime full engine.
+    # Sources come from SHANNON_PRIME_DIR (a shannon-prime-llama checkout).
+    # Core math:    ${SHANNON_PRIME_DIR}/lib/shannon-prime/core/
+    # Backends:     ${SHANNON_PRIME_DIR}/src/backends/{cuda,vulkan,adreno}/
+    # Engine:       ${SHANNON_PRIME_DIR}/src/engine/
+    # Tools/bridge: ${SHANNON_PRIME_DIR}/src/tools/
+    #
+    # CUDA: SP_CUDA is independent of GGML_CUDA so we can compile our .cu
+    # files without triggering ggml-cuda (which may fail on older MSVC).
+    # ========================================================================
+
+    if (NOT SHANNON_PRIME_DIR)
+        message(FATAL_ERROR "LLAMA_SHANNON_PRIME is ON but SHANNON_PRIME_DIR is not set. "
+                "Point it at your shannon-prime-llama checkout.")
