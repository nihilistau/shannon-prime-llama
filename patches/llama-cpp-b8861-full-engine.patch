+
+    # --- CUDA backends (independent of GGML_CUDA) ---
+    if (SP_CUDA)
+        enable_language(CUDA)
+        set(_SP_CUDA_SOURCES
+            ${_SP_BACK}/cuda/shannon_prime_cuda.cu
+            ${_SP_BACK}/cuda/shannon_prime_sqfree.cu
+            ${_SP_BACK}/cuda/shannon_prime_hier.cu
