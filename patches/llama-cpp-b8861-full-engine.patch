+// Shannon-Prime VHT2 KV cache compression hooks for llama.cpp.
+//
+// Activated when SHANNON_PRIME_ENABLED=1 is set in the environment.
+// Hook strategy: a post-graph_compute callback that walks the freshly-
+// written slots of the llama KV cache (layers[il].k / .v) and round-trips
+// their data through the Shannon-Prime compressed shadow cache in place.
+// Attention later reads the cache tensors directly, so seeing
+// reconstructed-from-compressed values. Single sync per decode call
+// instead of per-tensor — avoids the ggml_backend_sched eval-callback
+// serialization that killed throughput on mobile.
+//
+// CPU-only. Handles fp32 and fp16 KV cache types; other types are
+// passed through untouched (one-shot warning).
+
+#pragma once
+
+#ifdef LLAMA_SHANNON_PRIME
+
+#include <stdbool.h>
+#include "ggml.h"
+
+struct llama_model;
+struct llama_ubatch;
+struct llama_memory_context_i;
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+// Lazily initialise the global Shannon-Prime context from model hparams +
+// environment variables. No-op if already initialised or if
+// SHANNON_PRIME_ENABLED is not set.
+void llama_sp_maybe_init(const struct llama_model * model, int n_ctx);
+
+// Apply lattice-aligned RoPE frequency factors to model rope tensors.
+// Two sources, in priority order:
+//   1. SHANNON_PRIME_SIDECAR=<path>  — pre-baked .sp_freq_factors.bin file
+//      (optional: SHANNON_PRIME_ALPHA=0..1, default 1)
+//   2. Live-computed PrimePE factors from sp_llama_init() context
+//      (automatic when SHANNON_PRIME_ENABLED=1, controlled by
+//       SHANNON_PRIME_PE=1 and SHANNON_PRIME_PE_ALPHA=0.17)
+// Safe no-op when neither source is active, or no layer has a
+// rope_freqs / rope_long / rope_short tensor. Called once after model load.
+void llama_sp_maybe_apply_rope_sidecar(const struct llama_model * model);
+
+// Tear down the global context. Idempotent.
+void llama_sp_free(void);
+
+// True iff Shannon-Prime is active.
+bool llama_sp_is_enabled(void);
+
+// Post-decode hook. Called from llama_context::process_ubatch right after
+// graph_compute returns successfully. Walks the KV cache tensor storage
+// for the positions just written by this ubatch, round-trips K (and V
+// when its layout is contiguous per-position) through the Shannon-Prime
+// shadow cache, and writes the reconstructed values back in place.
+void llama_sp_post_compute(const struct llama_memory_context_i * mctx,
+                           const struct llama_ubatch * ubatch);
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif // LLAMA_SHANNON_PRIME
