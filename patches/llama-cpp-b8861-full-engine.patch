+        ${_SP_CORE}/shannon_prime_sqfree.c
+        ${_SP_CORE}/shannon_prime_modelpack.c
+        ${_SP_CORE}/shannon_prime_pe.c
+        ${_SP_TOOL}/shannon_prime_llama.c
+        ${_SP_TOOL}/shannon_prime_llama_sqfree.c
