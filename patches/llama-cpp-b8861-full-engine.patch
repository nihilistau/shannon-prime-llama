diff --git a/src/llama-shannon-prime.cpp b/src/llama-shannon-prime.cpp
new file mode 100644
index 0000000..e01a819
--- /dev/null
+++ b/src/llama-shannon-prime.cpp
@@ -0,0 +1,595 @@
+// Shannon-Prime VHT2 KV cache compression hooks for llama.cpp. See header.
+
+#ifdef LLAMA_SHANNON_PRIME
+
+#include "llama-shannon-prime.h"
+
+#include "llama-model.h"
+#include "llama-hparams.h"
+#include "llama-impl.h"
+#include "llama-kv-cache.h"
+#include "llama-batch.h"
+#include "llama-memory.h"
+
+#include "shannon_prime_llama.h"
+#include "shannon_prime.h"
+
+#include "ggml.h"
+
+#include <atomic>
+#include <cstdio>
+#include <cstdlib>
+#include <cstring>
+#include <vector>
+
+namespace {
+
+struct sp_state {
+    sp_llama_ctx_t * ctx = nullptr;
+    int head_dim_k = 0;
+    int head_dim_v = 0;
+    int n_layers   = 0;
+    int n_heads_kv = 0;
+};
+
+sp_state g_sp;
+
+// Sqfree+spinor aggressive path (opt-in via SHANNON_PRIME_SQFREE=1).
+// When active, the post-decode hook routes K and V through
+// sp_sqfree_cache_t instead of the WHT shadow cache.
+sp_sqfree_cache_t g_sp_sqfree_cache;
+bool              g_sp_sqfree_active = false;
+
+// Two thread-local (really decode-thread-local; the hook runs on the
+// same thread that called llama_decode) scratch buffers for the
+// fp16<->fp32 conversion on the post-decode path.
+thread_local std::vector<float> tl_gather;
+thread_local std::vector<float> tl_recon;
+
+inline float * get_scratch(std::vector<float> & v, size_t n) {
+    if (v.size() < n) v.resize(n);
+    return v.data();
+}
+
+// Backend-aware gather/scatter. The KV cache tensors can live on a CPU host
+// buffer (the default, and what pre-v1.05 assumed) or on a GPU device buffer
+// when llama.cpp offloads KV alongside model weights (`-ngl 99` without
+// `-nkvo`). On a host buffer a direct memcpy on `tensor->data` works; on a
+// device buffer we must round-trip through `ggml_backend_tensor_get` /
+// `ggml_backend_tensor_set` or the memcpy dereferences a GPU pointer and
+// segfaults mid-decode.
+inline bool gather_vec(const ggml_tensor * t, size_t off, int hd, float * out) {
+    const ggml_type type = t->type;
+    const size_t hd_bytes = (type == GGML_TYPE_F32) ? (size_t)hd * sizeof(float)
+                          : (type == GGML_TYPE_F16) ? (size_t)hd * sizeof(ggml_fp16_t)
+                          : 0;
+    if (hd_bytes == 0) return false;
+
+    if (type == GGML_TYPE_F32) {
+        if (t->buffer && ggml_backend_buffer_is_host(t->buffer)) {
+            std::memcpy(out, (const uint8_t *)t->data + off, hd_bytes);
+        } else {
+            ggml_backend_tensor_get(t, out, off, hd_bytes);
+        }
+        return true;
+    }
+
+    // F16: fetch raw bytes into a per-thread scratch, then widen to fp32.
+    thread_local std::vector<uint8_t> tl_raw;
+    if (tl_raw.size() < hd_bytes) tl_raw.resize(hd_bytes);
+    if (t->buffer && ggml_backend_buffer_is_host(t->buffer)) {
+        std::memcpy(tl_raw.data(), (const uint8_t *)t->data + off, hd_bytes);
+    } else {
+        ggml_backend_tensor_get(t, tl_raw.data(), off, hd_bytes);
+    }
+    ggml_fp16_to_fp32_row((const ggml_fp16_t *)tl_raw.data(), out, hd);
+    return true;
+}
+
+inline bool scatter_vec(ggml_tensor * t, size_t off, int hd, const float * in) {
+    const ggml_type type = t->type;
+    const size_t hd_bytes = (type == GGML_TYPE_F32) ? (size_t)hd * sizeof(float)
+                          : (type == GGML_TYPE_F16) ? (size_t)hd * sizeof(ggml_fp16_t)
+                          : 0;
+    if (hd_bytes == 0) return false;
+
+    if (type == GGML_TYPE_F32) {
+        if (t->buffer && ggml_backend_buffer_is_host(t->buffer)) {
+            std::memcpy((uint8_t *)t->data + off, in, hd_bytes);
+        } else {
+            ggml_backend_tensor_set(t, in, off, hd_bytes);
+        }
+        return true;
+    }
+
+    thread_local std::vector<uint8_t> tl_raw;
+    if (tl_raw.size() < hd_bytes) tl_raw.resize(hd_bytes);
+    ggml_fp32_to_fp16_row(in, (ggml_fp16_t *)tl_raw.data(), hd);
+    if (t->buffer && ggml_backend_buffer_is_host(t->buffer)) {
+        std::memcpy((uint8_t *)t->data + off, tl_raw.data(), hd_bytes);
+    } else {
+        ggml_backend_tensor_set(t, tl_raw.data(), off, hd_bytes);
+    }
+    return true;
+}
+
+} // namespace
+
+extern "C" void llama_sp_maybe_init(const struct llama_model * model, int n_ctx) {
+    if (g_sp.ctx != nullptr || g_sp_sqfree_active) return;
+    if (model == nullptr) return;
+
+    const auto & hp = model->hparams;
+
+    const int head_dim   = (int)hp.n_embd_head_k_full;
+    const int n_layers   = (int)hp.n_layer;
+    const int n_heads_kv = (int)hp.n_head_kv(0);
+    const int max_seq    = n_ctx > 16 ? n_ctx : 16;
+
+    if (head_dim <= 0 || n_layers <= 0 || n_heads_kv <= 0) {
+        std::fprintf(stderr,
+            "[Shannon-Prime] skipping init: invalid hparams (hd=%d nl=%d nhkv=%d)\n",
+            head_dim, n_layers, n_heads_kv);
+        return;
+    }
+
+    // --- Sqfree+spinor aggressive path --------------------------------------
+    const char * sqfree_env = std::getenv("SHANNON_PRIME_SQFREE");
+    if (sqfree_env && sqfree_env[0] == '1') {
+        sp_config_t cfg;
+        sp_config_init(&cfg, head_dim, n_layers, n_heads_kv);
+
+        // Parse K_BITS from env (e.g. "3,3,3,3,3"). Defaults to 5,4,4,4,5.
+        const char * kb = std::getenv("SHANNON_PRIME_K_BITS");
+        if (kb) {
+            int n = 0;
+            const char * p = kb;
+            while (*p && n < SP_MAX_BANDS) {
+                cfg.k_band_bits[n++] = atoi(p);
+                while (*p && *p != ',') p++;
+                if (*p == ',') p++;
+            }
+            cfg.k_n_bands = n;
+        } else {
+            cfg.k_n_bands       = 5;
+            cfg.k_band_bits[0]  = 5;
+            cfg.k_band_bits[1]  = 4;
+            cfg.k_band_bits[2]  = 4;
+            cfg.k_band_bits[3]  = 4;
+            cfg.k_band_bits[4]  = 5;
+        }
+        // V mirrors K under sqfree (cross-attn style, no RoPE asymmetry).
+        cfg.v_n_bands = cfg.k_n_bands;
+        std::memcpy(cfg.v_band_bits, cfg.k_band_bits,
+                    sizeof(int) * (size_t)cfg.k_n_bands);
+
+        const char * rb_env = std::getenv("SHANNON_PRIME_RESIDUAL_BITS");
+        int residual_bits = rb_env ? atoi(rb_env) : 3;
+        if (residual_bits < 1) residual_bits = 1;
+        if (residual_bits > 4) residual_bits = 4;
+
+        const char * spinor_env = std::getenv("SHANNON_PRIME_SPINOR");
+        const bool use_spinor = spinor_env && spinor_env[0] == '1';
+
+        int rc = sp_sqfree_cache_init(&g_sp_sqfree_cache, &cfg,
+                                      max_seq, residual_bits, use_spinor);
+        if (rc != 0) {
+            std::fprintf(stderr,
+                "[Shannon-Prime SQFREE] init failed (rc=%d); falling back to WHT\n", rc);
+        } else {
+            g_sp_sqfree_active = true;
+            g_sp.head_dim_k = head_dim;
+            g_sp.head_dim_v = (int)hp.n_embd_head_v_full;
+            g_sp.n_layers   = n_layers;
+            g_sp.n_heads_kv = n_heads_kv;
+            std::fprintf(stderr,
+                "[Shannon-Prime SQFREE] active: hd=%d pad_dim=%d n_layers=%d n_heads_kv=%d "
+                "residual_bits=%d spinor=%s\n",
+                head_dim, g_sp_sqfree_cache.pad_dim, n_layers, n_heads_kv,
+                residual_bits, use_spinor ? "on" : "off");
+            return;
+        }
+    }
+
+    // --- WHT ship path (default) --------------------------------------------
+    sp_llama_params_t params = {};
+    params.head_dim    = head_dim;
+    params.n_layers    = n_layers;
+    params.n_heads_kv  = n_heads_kv;
+    params.max_seq_len = max_seq;
+    params.backend     = decltype(params.backend)(0); // SP_BACKEND_CPU; env override in sp_llama_init
+    params.gpu_context = nullptr;
+
+    g_sp.ctx = sp_llama_init(&params);
+    if (g_sp.ctx == nullptr) return;
+
+    g_sp.head_dim_k = params.head_dim;
+    g_sp.head_dim_v = (int)hp.n_embd_head_v_full;
+    g_sp.n_layers   = params.n_layers;
+    g_sp.n_heads_kv = params.n_heads_kv;
+
+    std::fprintf(stderr,
+        "[Shannon-Prime] enabled: head_dim_k=%d head_dim_v=%d n_layers=%d n_heads_kv=%d n_ctx=%d\n",
+        g_sp.head_dim_k, g_sp.head_dim_v, g_sp.n_layers, g_sp.n_heads_kv, params.max_seq_len);
+}
+
+extern "C" void llama_sp_free(void) {
+    if (g_sp.ctx) {
+        sp_llama_free(g_sp.ctx);
+        g_sp.ctx = nullptr;
+    }
+    if (g_sp_sqfree_active) {
+        sp_sqfree_cache_free(&g_sp_sqfree_cache);
+        g_sp_sqfree_active = false;
+    }
+}
+
+extern "C" bool llama_sp_is_enabled(void) {
+    return g_sp.ctx != nullptr || g_sp_sqfree_active;
+}
+
+// Helpers for the sidecar apply path.
+namespace {
+
+// Load `path` (must exist) into `out` as fp32 entries. Returns number of
+// fp32 entries read; 0 on any failure.
+size_t load_sidecar_fp32(const char * path, std::vector<float> & out) {
+    std::FILE * fp = std::fopen(path, "rb");
+    if (!fp) return 0;
+    std::fseek(fp, 0, SEEK_END);
+    long sz = std::ftell(fp);
+    std::fseek(fp, 0, SEEK_SET);
+    if (sz <= 0 || (sz % (long)sizeof(float)) != 0) {
+        std::fclose(fp);
+        return 0;
+    }
+    size_t n = (size_t)sz / sizeof(float);
+    out.resize(n);
+    size_t got = std::fread(out.data(), sizeof(float), n, fp);
+    std::fclose(fp);
+    return got;
+}
+
+// Pick the rope-factor tensor a layer prefers: rope_freqs > rope_long > rope_short.
+// Mirrors the preference order in llama_model::get_rope_factors.
+ggml_tensor * pick_rope_tensor(const llama_layer & layer) {
+    if (layer.rope_freqs) return layer.rope_freqs;
+    if (layer.rope_long)  return layer.rope_long;
+    if (layer.rope_short) return layer.rope_short;
+    return nullptr;
+}
+
+} // namespace
+
+// Shared: write freq_factors into all rope tensors across model layers.
+// factors must point to n_factors floats. alpha blends against existing values.
+static void apply_rope_factors(const struct llama_model * model,
+                               const float * factors, size_t n_factors,
+                               float alpha, const char * source_tag) {
+    int patched  = 0;
+    int skipped  = 0;
+    int mismatch = 0;
+    std::vector<float> scratch;
+
+    for (size_t il = 0; il < model->layers.size(); il++) {
+        ggml_tensor * t = pick_rope_tensor(model->layers[il]);
+        if (!t) { skipped++; continue; }
+        // Skip tensors whose backend buffer isn't bound yet (e.g. graph-time
+        // scratch tensors that look real but have no host/device data).
+        // ggml_backend_tensor_set would assert on null data.
+        if (!t->buffer || !t->data) { skipped++; continue; }
+        if ((size_t)t->ne[0] != n_factors || t->ne[1] != 1 || t->type != GGML_TYPE_F32) {
+            if (mismatch == 0) {
+                std::fprintf(stderr,
+                    "[Shannon-Prime] %s layout mismatch at layer %zu: "
+                    "tensor ne=[%lld,%lld,%lld,%lld] type=%d, factors n=%zu — skipping\n",
+                    source_tag, il, (long long)t->ne[0], (long long)t->ne[1],
+                    (long long)t->ne[2], (long long)t->ne[3], (int)t->type, n_factors);
+            }
+            mismatch++;
+            continue;
+        }
+
+        if (alpha == 1.0f) {
+            ggml_backend_tensor_set(t, factors, 0, n_factors * sizeof(float));
+        } else {
+            scratch.resize(n_factors);
+            ggml_backend_tensor_get(t, scratch.data(), 0, n_factors * sizeof(float));
+            for (size_t i = 0; i < n_factors; i++) {
+                scratch[i] = (1.0f - alpha) * scratch[i] + alpha * factors[i];
+            }
+            ggml_backend_tensor_set(t, scratch.data(), 0, n_factors * sizeof(float));
+        }
+        patched++;
+    }
+
+    std::fprintf(stderr,
+        "[Shannon-Prime] %s applied: alpha=%.3f n_freqs=%zu "
+        "patched=%d skipped=%d mismatched=%d\n",
+        source_tag, alpha, n_factors, patched, skipped, mismatch);
+}
+
+extern "C" void llama_sp_maybe_apply_rope_sidecar(const struct llama_model * model) {
+    if (!model) return;
+
+    // Priority 1: explicit sidecar file (pre-baked factors from sp_inject_freqs.py)
+    const char * sidecar_env = std::getenv("SHANNON_PRIME_SIDECAR");
+    if (sidecar_env && *sidecar_env) {
+        std::vector<float> sidecar;
+        size_t n_sidecar = load_sidecar_fp32(sidecar_env, sidecar);
+        if (n_sidecar == 0) {
+            std::fprintf(stderr,
+                "[Shannon-Prime] sidecar '%s' unreadable or empty — skipping\n",
+                sidecar_env);
+            return;
+        }
+
+        const char * alpha_env = std::getenv("SHANNON_PRIME_ALPHA");
+        float alpha = alpha_env ? (float)std::atof(alpha_env) : 1.0f;
+        if (alpha < 0.0f) alpha = 0.0f;
+        if (alpha > 1.0f) alpha = 1.0f;
+
+        apply_rope_factors(model, sidecar.data(), n_sidecar, alpha, "sidecar");
+        return;
+    }
+
+    // Priority 2: live-computed PrimePE factors from sp_llama_init()
+    // These are lattice-aligned freq_factors computed at context creation.
+    // No sidecar file needed — zero user action required.
+    if (g_sp.ctx) {
+        const float * factors = sp_llama_get_freq_factors(g_sp.ctx);
+        int n_freqs = sp_llama_get_n_freqs(g_sp.ctx);
+        if (factors && n_freqs > 0) {
+            apply_rope_factors(model, factors, (size_t)n_freqs, 1.0f, "PrimePE");
+            return;
+        }
+    }
+
+    // Neither path active — no-op (standard geometric RoPE unchanged)
+}
+
+extern "C" void llama_sp_post_compute(const struct llama_memory_context_i * mctx,
+                                      const struct llama_ubatch * ubatch) {
+    if ((!g_sp.ctx && !g_sp_sqfree_active) || !mctx || !ubatch) return;
+
+    // Diagnostic toggles. SHANNON_PRIME_SKIP_K / SKIP_V can bypass one side
+    // of the round-trip for isolating which half is responsible for a
+    // quality regression.
+    static const char * sk_env  = std::getenv("SHANNON_PRIME_SKIP_K");
+    static const char * sv_env  = std::getenv("SHANNON_PRIME_SKIP_V");
+    static const bool   skip_k  = sk_env && sk_env[0] == '1';
+    static const bool   skip_v  = sv_env && sv_env[0] == '1';
+
+    // Only the unified KV cache path is handled. ISWA / hybrid caches are
+    // out of scope for the first post-decode hook iteration.
+    auto * kvc = dynamic_cast<const llama_kv_cache_context *>(mctx);
+    if (!kvc) return;
+
+    auto * kv = kvc->get_kv();
+    if (!kv) return;
+
+    const auto & sinfos_vec = kvc->get_cur_sinfo();
+    if (sinfos_vec.empty()) return;
+    const auto & sinfo = sinfos_vec[kvc->get_cur_idx()];
+    const auto & layers = kv->get_layers();
+    const int n_tokens  = (int)ubatch->n_tokens;
+    if (n_tokens <= 0) return;
+    if (sinfo.idxs.empty() || sinfo.idxs[0].empty()) return;
+
+    const int hd_k = g_sp.head_dim_k;
+    const int hd_v = g_sp.head_dim_v;
+    const int nhk  = g_sp.n_heads_kv;
+
+    // One-shot diagnostic: log what V path we're taking so we can tell
+    // contiguous-per-position from the v_trans strided variant apart.
+    static std::atomic<bool> vpath_logged{false};
+    if (!layers.empty() && layers[0].v) {
+        bool expected = false;
+        if (vpath_logged.compare_exchange_strong(expected, true)) {
+            bool vcp = (size_t)layers[0].v->nb[1] <= (size_t)layers[0].v->nb[2];
+            std::fprintf(stderr,
+                "[Shannon-Prime] V path: %s (v->nb[1]=%zu, v->nb[2]=%zu) skip_k=%d skip_v=%d\n",
+                vcp ? "CONTIGUOUS-PER-POS" : "STRIDED-V_TRANS",
+                (size_t)layers[0].v->nb[1], (size_t)layers[0].v->nb[2],
+                skip_k ? 1 : 0, skip_v ? 1 : 0);
+        }
+    }
+
+    float * gather = get_scratch(tl_gather, (size_t)(hd_k > hd_v ? hd_k : hd_v));
+    float * recon  = get_scratch(tl_recon,  (size_t)(hd_k > hd_v ? hd_k : hd_v));
+
+    // Walk each kv layer × each newly-written position × each head.
+    // Round-trip K always. Round-trip V only when v_trans=false so the
+    // per-position per-head vector is contiguous in memory. When v_trans
+    // is true (default), V lives in [head_dim, head, position] order with
+    // position innermost — gather/scatter would need strided access per
+    // element; deferred.
+    for (size_t ikv = 0; ikv < layers.size(); ++ikv) {
+        const auto & L = layers[ikv];
+        ggml_tensor * k = L.k;
+        ggml_tensor * v = L.v;
+        if (!k) continue;
+        // k->data is only populated for host-resident tensors; for device
+        // buffers the actual storage is behind ggml_backend_tensor_*. Use
+        // the presence of any bound buffer as the liveness check.
+        if (!k->buffer && !k->data) continue;
+
+        const ggml_type tk = k->type;
+        const size_t    ek = ggml_type_size(tk);
+        const size_t    n_embd_k_gqa = (size_t)k->ne[0]; // head_dim * nhk
+        // Defensive: if the cache's head layout doesn't match what we
+        // initialised against, skip this layer rather than crash.
+        if (n_embd_k_gqa != (size_t)hd_k * (size_t)nhk) continue;
+        const size_t k_pos_stride = n_embd_k_gqa * ek;
+
+        const int il = (int)L.il;
+
+        // Slot 0 in the shadow cache is scratch for round-trip only (we
+        // don't use it as a long-term store here — the live KV cache IS
+        // the store; Shannon-Prime only lends its compress/decompress).
+        // k may live on a device buffer (-ngl 99 without -nkvo) — gather/
+        // scatter route through ggml_backend_tensor_{get,set} in that case.
+
+        if (skip_k) goto do_v;
+
+        // SHANNON_PRIME_DUMP_K=<path> appends raw K vectors (hd_k × fp32) to
+        // <path>; tools/sp_auto_bands.py consumes the dump to compute a per-band
+        // VHT2 energy-weighted bit allocation. Opened once, stream-writes,
+        // closed at process exit (OS cleans up). Hard cap via LIMIT env so we
+        // don't blow up a warmup run into gigabytes.
+        static std::FILE * dump_fp = nullptr;
+        static long long   dump_count = 0;
+        static long long   dump_limit = 0;
+        static std::atomic<bool> dump_init{false};
+        if (!dump_init.exchange(true)) {
+            const char * dp = std::getenv("SHANNON_PRIME_DUMP_K");
+            if (dp && *dp) {
+                dump_fp = std::fopen(dp, "wb");
+                const char * lim_s = std::getenv("SHANNON_PRIME_DUMP_K_LIMIT");
+                dump_limit = lim_s ? std::atoll(lim_s) : 8192;
+                std::fprintf(stderr,
+                    "[Shannon-Prime] K dump → %s (limit=%lld vectors, hd=%d)\n",
+                    dp, dump_limit, hd_k);
+            }
+        }
+
+        for (int t = 0; t < n_tokens; ++t) {
+            uint32_t slot = sinfo.idxs[0][t];
+            const size_t pos_off = (size_t)slot * k_pos_stride;
+
+            for (int h = 0; h < nhk; ++h) {
+                const size_t off = pos_off + (size_t)h * hd_k * ek;
+                if (!gather_vec(k, off, hd_k, gather)) continue;
+
+                if (dump_fp && (dump_limit == 0 || dump_count < dump_limit)) {
+                    std::fwrite(gather, sizeof(float), hd_k, dump_fp);
+                    dump_count++;
+                    if (dump_count == dump_limit) std::fflush(dump_fp);
+                }
+
+                if (g_sp_sqfree_active) {
+                    sp_sqfree_write_k(&g_sp_sqfree_cache, il, h, 0, gather);
+                    sp_sqfree_read_k (&g_sp_sqfree_cache, il, h, 0, recon);
+                } else {
+                    sp_llama_write_k(g_sp.ctx, il, h, 0, gather);
+                    sp_llama_read_k (g_sp.ctx, il, h, 0, recon);
+                }
+
+                scatter_vec(k, off, hd_k, recon);
+            }
+        }
+
+        // V — only when not transposed. The adjacency check matches
+        // llama_kv_cache::get_v's v_trans=false branch.
+        do_v:
+        if (skip_v) continue;
+        if (v && (v->buffer || v->data)) {
+            const ggml_type tv = v->type;
+            const size_t    ev = ggml_type_size(tv);
+            // When v_trans is false, v->nb[1] == row_size(head_dim)
+            // and positions live at v->nb[2]. When v_trans is true,
+            // v->nb[1] > v->nb[2] (positions innermost).
+            const bool v_contig_per_pos = (size_t)v->nb[1] <= (size_t)v->nb[2];
+
+            if (v_contig_per_pos) {
+                const size_t n_embd_v_gqa = (size_t)v->ne[0]; // head_dim * nhk
+                if (n_embd_v_gqa == (size_t)hd_v * (size_t)nhk) {
+                    const size_t v_pos_stride = n_embd_v_gqa * ev;
+
+                    for (int t = 0; t < n_tokens; ++t) {
+                        uint32_t slot = sinfo.idxs[0][t];
+                        const size_t pos_off = (size_t)slot * v_pos_stride;
+
+                        for (int h = 0; h < nhk; ++h) {
+                            const size_t off = pos_off + (size_t)h * hd_v * ev;
+                            if (!gather_vec(v, off, hd_v, gather)) continue;
+
+                            if (g_sp_sqfree_active) {
+                                sp_sqfree_write_v(&g_sp_sqfree_cache, il, h, 0, gather);
+                                sp_sqfree_read_v (&g_sp_sqfree_cache, il, h, 0, recon);
+                            } else {
+                                sp_llama_write_v(g_sp.ctx, il, h, 0, gather);
+                                sp_llama_read_v (g_sp.ctx, il, h, 0, recon);
+                            }
+
+                            scatter_vec(v, off, hd_v, recon);
+                        }
+                    }
+                }
+            } else {
+                // v_trans=true path: storage layout is
+                //   v[stream, head, head_dim_idx, position]
+                // with `position` innermost (stride = element_size),
+                // `head_dim_idx` at stride kv_size elements,
+                // `head`        at stride kv_size*head_dim elements.
+                // So for a fixed (head h, position p) the hd floats that
+                // make up the V vector live at a *strided* set of offsets.
+                // We gather hd elements into a contiguous scratch, run the
+                // shannon-prime round-trip, scatter back.
+                const size_t n_embd_v_gqa = (size_t)v->ne[0]; // head_dim * nhk
+                // The v_trans=true path does per-element strided access
+                // directly via v->data; that's only valid when V lives on a
+                // host buffer. Skip silently on device buffers — a GPU
+                // v_trans=true compressor needs its own kernel (deferred).
+                if (v->buffer && !ggml_backend_buffer_is_host(v->buffer)) {
+                    goto next_layer;
+                }
+                if (n_embd_v_gqa == (size_t)hd_v * (size_t)nhk) {
+                    const uint32_t kv_size = kv->get_size();
+                    const size_t   head_stride_elts  = (size_t)kv_size * hd_v;  // elements between heads
+                    const size_t   inner_stride_elts = (size_t)kv_size;          // elements between head_dim indices
+                    uint8_t *      vdata = (uint8_t *)v->data;
+
+                    for (int t = 0; t < n_tokens; ++t) {
+                        uint32_t slot = sinfo.idxs[0][t];
+                        const size_t slot_off_elts = (size_t)slot;
+
+                        for (int h = 0; h < nhk; ++h) {
+                            const size_t head_off_elts = (size_t)h * head_stride_elts;
+
+                            // Gather hd strided floats from the cache.
+                            if (tv == GGML_TYPE_F32) {
+                                const float * vp = (const float *)vdata;
+                                for (int i = 0; i < hd_v; ++i) {
+                                    gather[i] = vp[head_off_elts + (size_t)i * inner_stride_elts + slot_off_elts];
+                                }
+                            } else if (tv == GGML_TYPE_F16) {
+                                const ggml_fp16_t * vp = (const ggml_fp16_t *)vdata;
+                                for (int i = 0; i < hd_v; ++i) {
+                                    gather[i] = ggml_fp16_to_fp32(vp[head_off_elts + (size_t)i * inner_stride_elts + slot_off_elts]);
+                                }
+                            } else {
+                                continue;
+                            }
+
+                            if (g_sp_sqfree_active) {
+                                sp_sqfree_write_v(&g_sp_sqfree_cache, il, h, 0, gather);
+                                sp_sqfree_read_v (&g_sp_sqfree_cache, il, h, 0, recon);
+                            } else {
+                                sp_llama_write_v(g_sp.ctx, il, h, 0, gather);
+                                sp_llama_read_v (g_sp.ctx, il, h, 0, recon);
+                            }
+
+                            // Scatter the reconstructed values back to the
+                            // same strided locations.
+                            if (tv == GGML_TYPE_F32) {
+                                float * vp = (float *)vdata;
+                                for (int i = 0; i < hd_v; ++i) {
+                                    vp[head_off_elts + (size_t)i * inner_stride_elts + slot_off_elts] = recon[i];
+                                }
+                            } else if (tv == GGML_TYPE_F16) {
+                                ggml_fp16_t * vp = (ggml_fp16_t *)vdata;
+                                for (int i = 0; i < hd_v; ++i) {
+                                    vp[head_off_elts + (size_t)i * inner_stride_elts + slot_off_elts] = ggml_fp32_to_fp16(recon[i]);
+                                }
+                            }
+                        }
+                    }
+                }
+            }
+        }
+        next_layer:;
+    }
+}
+
+#endif // LLAMA_SHANNON_PRIME
