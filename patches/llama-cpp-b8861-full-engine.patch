+            message(STATUS "Shannon-Prime: FP8/FP4 CUDA kernels enabled (SP_FP8)")
+        endif()
+
+        add_library(shannon_prime_cuda STATIC ${_SP_CUDA_SOURCES})
+        target_include_directories(shannon_prime_cuda PUBLIC ${_SP_INCLUDES})
+        target_compile_definitions(shannon_prime_cuda PUBLIC LLAMA_SHANNON_PRIME SP_HAVE_CUDA)
